## This file must *NOT* be checked into Version Control Systems,
# as it contains information specific to your local configuration.
#
# Android Studio generates and rewrites local.properties on its own, so it now holds
# only the SDK location. Every account-specific value — application ids, Firebase,
# AdMob, signing, backend URL, remote config — lives in secrets.properties:
#
#     cp secrets.properties.example secrets.properties
#     ./scripts/sync-config.sh
#
# Values still present in local.properties keep working as a fallback, but new ones
# belong in secrets.properties.

sdk.dir=
