{
  "name": "devicedna-sync-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DeviceDNA_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DeviceDNA_DB --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "firebase-auth-cloudflare-workers": "^2.0.6",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
