platform :ios, '16.0'

target 'DeviceDNAApp' do
  use_frameworks!

  # Auth
  pod 'FirebaseCore'
  pod 'FirebaseAuth'
  pod 'GoogleSignIn'

  # Remote config: GitLive firebase-firestore in the shared framework links against the native
  # Firestore SDK, so its symbols must resolve at final app link.
  pod 'FirebaseFirestore'

  # Ads (AdMob + consent management for EEA/UK + ATT)
  pod 'Google-Mobile-Ads-SDK'
  pod 'GoogleUserMessagingPlatform'
end

# The DeviceDNAWidgets extension target uses only system frameworks (WidgetKit/SwiftUI) —
# no pods required. The shared Kotlin framework is embedded via the
# `embedAndSignAppleFrameworkForXcode` Run Script build phase, not CocoaPods.
