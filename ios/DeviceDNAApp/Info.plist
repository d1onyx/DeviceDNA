<plist version="1.0">
<dict>
	<!-- ── Identity (Xcode substitutes build settings) ─────────────────── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>DeviceDNA</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>AppBuildConfiguration</key>
	<string>$(CONFIGURATION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>

	<!-- ── Compose Multiplatform requirement ─────────────────────────────
	     Without this, ComposeUIViewController's PlistSanityCheck deliberately crashes
	     the app at launch (abort() from terminateWithUnhandledException) so ProMotion
	     (120Hz) devices don't silently get throttled animations. ── -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<!-- ── Deep links: widgets and notifications open devicedna://open/<route> ── -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(IOS_DEEP_LINK_SCHEME)</string>
			</array>
		</dict>
		<dict>
			<!-- Google Sign-In callback. GIDSignIn.signIn(withPresenting:) crashes with an
			     NSException at launch of the sign-in flow if this scheme isn't registered —
			     value is REVERSED_CLIENT_ID from GoogleService-Info.plist. -->
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).google</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
			</array>
		</dict>
	</array>

	<!-- ── Background refresh (battery history, widgets, smart alerts) ─── -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>$(IOS_BACKGROUND_TASK_ID)</string>
	</array>

	<!-- ── AdMob ─────────────────────────────────────────────────────────
	     Test application id — replace with the production GADApplicationIdentifier
	     from the AdMob console before submitting. -->
	<key>GADApplicationIdentifier</key>
	<string>$(IOS_ADMOB_APP_ID)</string>

	<!-- ATT: shown by UMP only when consent requires tracking. Reviewers check that
	     this string honestly explains the purpose. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>Your data will be used to deliver personalized ads and to measure advertising performance.</string>

