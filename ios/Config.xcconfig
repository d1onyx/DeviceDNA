// Build-time configuration, mirrors Android's local.properties -> BuildConfig pattern:
// a checked-in default here, optionally overridden by a gitignored Local.xcconfig.
//
// `$()` is an empty-substitution escape — xcconfig treats a bare `//` anywhere on a
// line (even inside a value) as the start of a comment, so a URL's scheme must be
// broken up like this or everything after `//` silently gets dropped.

// Cloudflare Worker sync backend (no trailing slash). Must match Android's
// `syncBaseUrl` (local.properties / -PsyncBaseUrl, see android/build.gradle.kts).
SYNC_BASE_URL = https:/$()/devicedna-sync.ravehent.workers.dev

#include? "Local.xcconfig"
