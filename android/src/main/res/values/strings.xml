    <string name="auth_badge_setup">Setup needed</string>
    <string name="auth_title">Secure device intelligence starts here.</string>
    <string name="auth_subtitle">Sign in to unlock a trusted DeviceDNA profile while keeping hardware diagnostics local-first and under your control.</string>
    <string name="auth_value_private">Private by default</string>
    <string name="auth_value_sync">Firebase Auth</string>
    <string name="auth_value_device">Device profile</string>
    <string name="auth_google">Continue with Google</string>
    <string name="auth_apple">Continue with Apple</string>
    <string name="common_unavailable_ios">Not available on iOS</string>
    <string name="auth_terms">By continuing, you use Firebase Authentication for identity. Signed-in sync may upload device diagnostics to the DeviceDNA backend.</string>
    <string name="auth_privacy_accept_prefix">I have read and accept the</string>
    <string name="auth_privacy_link">Privacy Policy</string>
    <string name="auth_privacy_required">You need to accept the Privacy Policy to continue.</string>
    <string name="auth_privacy_policy_title">Privacy Policy</string>
    <string name="auth_privacy_policy_summary">How your device data is stored on third-party services.</string>
    <string name="auth_privacy_policy_body">DeviceDNA collects and syncs your Firebase account identifier, Android ID, device summary, diagnostic snapshot, sync timestamps, and Premium status to provide signed-in sync, account checks, and subscription verification. Diagnostics can include hardware, OS, battery, storage, network, sensor, camera metadata, installed app inventory, and health information. Google sign-in uses Firebase Authentication. Real Premium purchases use Google Play Billing and backend verification. Ads may be served by Google Mobile Ads. Public IP lookup contacts api.ipify.org only when enabled. DeviceDNA does not sell personal or sensitive data. You can sign out, revoke permissions, disable optional network features, and request backend data deletion through the developer contact in the Google Play listing.</string>
    <string name="auth_privacy_policy_close">Got it</string>

