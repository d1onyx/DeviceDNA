# ═════════════════════════════════════════════════════════════════════════════
# DeviceDNA — single source of truth for every account-specific value.
#
#   cp secrets.properties.example secrets.properties   # then fill in the blanks
#   ./scripts/sync-config.sh                           # push values everywhere
#
# Nothing here is read directly by the app at runtime. Gradle reads this file for
# Android build config and signing; sync-config.sh generates backend/.dev.vars,
# .firebaserc and ios/settings.local.yml from it; setup-cloudflare.sh uploads the
# server-side values as Cloudflare Worker secrets.
#
# secrets.properties is gitignored. Never commit it. local.properties keeps only
# sdk.dir (Android Studio rewrites that file).
#
# Legend:
#   [required]        build fails without it (release builds; debug uses a default)
#   [required-debug]  needed for a working debug build too
#   [optional]        feature stays off when empty
#   [secret]          real credential — treat like a password
# ═════════════════════════════════════════════════════════════════════════════


# ── App identity ─────────────────────────────────────────────────────────────
# Must match Firebase, Play Console, App Store Connect and the backend.

# [required] Android package name, e.g. com.acme.devicedna
androidApplicationId=

# [optional] Shown in the Firebase console when the project is created.
appDisplayName=DeviceDNA

# [required] iOS bundle ids. The widget id must be a child of the app id.
iosBundleId=
iosWidgetBundleId=
iosAppGroupId=
iosBackgroundTaskId=

# [required] Custom URL scheme for deep links into the app.
iosDeepLinkScheme=


# ── Firebase Auth (Google Sign-In) ───────────────────────────────────────────
# Firebase Console → Project settings → General.
# Config files (android/google-services.json, ios/.../GoogleService-Info.plist)
# are downloaded by scripts/setup-firebase-auth.sh — do not fill them in by hand.

# [required] Project id, e.g. devicedna-prod. Also written to .firebaserc.
firebaseProjectId=

# [required][secret] Web API key: Project settings → General → Web API Key.
# The Worker uses it to verify Firebase ID tokens.
firebaseWebApiKey=

# [required] REVERSED_CLIENT_ID from ios/DeviceDNAApp/GoogleService-Info.plist.
# Registers the OAuth redirect scheme Google Sign-In needs at runtime.
# Format: com.googleusercontent.apps.<digits>-<hash>
iosGoogleReversedClientId=


# ── Backend: Cloudflare Worker + D1 ──────────────────────────────────────────

# [required] Worker name. Determines the URL: <name>.<subdomain>.workers.dev
# Rendered into backend/wrangler.toml by scripts/sync-config.sh.
cloudflareWorkerName=devicedna-sync

# [required] KV namespace id caching Google's JWKS. Not a secret, but account-specific.
# Created once by backend/setup-cloudflare.sh, which writes the id back here.
cloudflareKvId=

# [required] Deployed Worker URL, no trailing slash.
# Printed by setup-cloudflare.sh: https://<worker>.<subdomain>.workers.dev
syncBaseUrl=

# [required] Cloudflare D1 database id. Not a secret, but account-specific.
# Created once by backend/setup-cloudflare.sh, which writes the id back here.
cloudflareD1Id=

# [optional][secret] Guards the /internal subscription upsert endpoints.
internalApiKey=

# [optional][secret] Shared token guarding the Google Play RTDN webhook.
# Pub/Sub push endpoint: https://<worker-url>/play/notifications?token=<this>
playRtdnVerificationToken=

# [optional] Local `wrangler dev` only. Enables POST /v1/subscription/dev/activate,
# which grants a 10-minute Premium subscription. NEVER set for production.
devSubscriptionsEnabled=true


# ── Billing: Google Play + StoreKit ──────────────────────────────────────────

# [required] Subscription product id, must match Play Console.
premiumSubProductId=devicedna_premium

# [optional] Backend-side Play verification. Default to androidApplicationId and
# premiumSubProductId when left empty.
googlePlayPackageName=
googlePlayPremiumProductId=

# [optional][secret] Real Google Play purchase verification. Google Cloud Console →
# IAM → Service Accounts → key (JSON). Grant it access in Play Console → API access.
# The private key must be a single line with literal \n escapes.
googlePlayServiceAccountEmail=
googlePlayPrivateKey=

# [required] StoreKit product id, must match App Store Connect.
iosStoreKitPremiumProductId=

# [optional] Force the billing implementation. Default: debug = dev billing
# (instant unlock, no Play needed), release = real Play Billing.
# realBilling=false

# [optional] When true, the debug dev-purchase goes through the backend and is
# persisted to D1 end-to-end instead of unlocking locally. Default: false.
# devSubscriptionUseBackend=false


# ── AdMob ────────────────────────────────────────────────────────────────────
# AdMob Console → Apps → App settings / Ad units.
# Leave empty in debug: Google's official test ids are used automatically.

# [required] Android
adMobAppId=
adMobBannerAdUnitId=
adMobInterstitialAdUnitId=

# [required] iOS
iosAdMobAppId=
iosAdMobBannerAdUnitId=
iosAdMobInterstitialAdUnitId=


# ── Remote config sync ───────────────────────────────────────────────────────
# Reads a signed config document from a separate Firestore project. In debug,
# empty values keep it inactive (no-op). See the ops runbook.

# [required] Firestore project holding the config document.
cfgProjectId=
cfgAppId=

# [required][secret] Web API key of that project.
cfgApiKey=

# [optional] Firestore document path. Must match on Android and iOS.
cfgDocPath=cfg/state

# [required] Ed25519 public key, base64 of the raw 32 bytes. Not secret — it only
# verifies the document signature. Must match the private key used to sign.
cfgPubKey=


# ── Android signing ──────────────────────────────────────────────────────────

# [optional] Debug signing. Gives a stable project-specific SHA-1 you can register
# in Firebase for local Google Sign-In. All four values, or none.
# Generate once: keytool -genkey -v -keystore android/debug.keystore \
#   -storepass android -alias androiddebugkey -keypass android \
#   -keyalg RSA -keysize 2048 -validity 10000 -dname "CN=Android Debug,O=Android,C=US"
debugStoreFile=android/debug.keystore
debugStorePassword=android
debugKeyAlias=androiddebugkey
debugKeyPassword=android

# [required-release][secret] Upload keystore. All four values, or release builds fail.
# CI may instead set ANDROID_RELEASE_STORE_FILE / _STORE_PASSWORD / _KEY_ALIAS / _KEY_PASSWORD.
# Path is relative to the repo root, or absolute.
releaseStoreFile=
releaseStorePassword=
releaseKeyAlias=
releaseKeyPassword=
